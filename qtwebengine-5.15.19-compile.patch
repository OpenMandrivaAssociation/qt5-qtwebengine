-#endif
+// with an explicit #include <sys/syscall.h> + #undef + #define 1.  That must be
+// done before any other header in this file or in the including .cc can bring
+// in a system definition; doing it at the bottom (as previous attempts did)
+// lets the problematic macro be live when we reach the late #define, producing
+// the "expected identifier before numeric constant" error again.
 
